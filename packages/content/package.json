{
  "name": "@miuprep/content",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node dist/standard.test.js",
    "audit:english": "npm run build && node dist/audit-english.js",
    "audit:ielts-cpe-deep": "npm run build && node dist/deep-audit-ielts-cpe.js",
    "audit:cae-deep": "npm run build && node dist/deep-audit-cae.js",
    "normalize:cae": "npm run build && node dist/normalize-cae-mocks.js",
    "export:audit:english": "npm run build && node dist/export-english-audit.js",
    "export:math6": "npm run build && node dist/export-math6-content.js --fail-on-adapter-error",
    "audit:math6-display": "node ../../scripts/audit-math6-display.js",
    "guard:math6": "npm run build && node dist/guard-math6-content.js --fail-on-adapter-error",
    "export:audit:math6": "npm run build && node dist/guard-math6-content.js --outDir reports/content-quality --quiet",
    "guard:english": "npm run build && node dist/guard-english-content.js --fail-on-adapter-error",
    "guard:miumath": "npm run build && node dist/guard-miumath-content.js --fail-on-adapter-error",
    "export:audit:miumath": "npm run build && node dist/guard-miumath-content.js --outDir reports/content-quality --quiet",
    "sync:portal-quality": "npm run build && node dist/sync-portal-content-quality-snapshot.js",
    "guard:sat": "npm run build && node dist/guard-sat-content.js --fail-on-adapter-error"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
