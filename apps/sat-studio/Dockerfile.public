FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV SAT_STUDIO_HOST=0.0.0.0
ENV SAT_STUDIO_PORT=8765
ENV SAT_STUDIO_PUBLIC_DB=/app/data/sat_studio_public.sqlite3

WORKDIR /app

COPY requirements-public.txt .
RUN pip install --no-cache-dir -r requirements-public.txt

COPY . .
RUN mkdir -p /app/data/public-backups

EXPOSE 8765

CMD ["python", "scripts/run_public_backend.py"]
