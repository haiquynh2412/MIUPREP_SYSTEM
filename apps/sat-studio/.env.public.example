SAT_STUDIO_HOST=0.0.0.0
SAT_STUDIO_PORT=8765
SAT_STUDIO_PUBLIC_DB=/app/data/sat_studio_public.sqlite3
SAT_STUDIO_ALLOWED_ORIGINS=https://your-sat-studio-domain.example
SAT_STUDIO_RATE_LIMIT=120
SAT_STUDIO_AUTH_RATE_LIMIT=20
SAT_STUDIO_RATE_WINDOW_SECONDS=60
SAT_STUDIO_RATE_LIMIT_BACKEND=memory
SAT_STUDIO_RATE_LIMIT_MAX_BUCKETS=50000
# For horizontal production scale-out, use redis after provisioning Redis:
# SAT_STUDIO_RATE_LIMIT_BACKEND=redis
# SAT_STUDIO_REDIS_URL=redis://redis:6379/0
SAT_STUDIO_RATE_LIMIT_REDIS_FAIL_CLOSED=true
SAT_STUDIO_RATE_LIMIT_REDIS_PREFIX=sat-studio:public-rate
SAT_STUDIO_ACCESS_LOG_JSONL=/app/data/public-access.jsonl
SAT_STUDIO_METRICS_MAX_PATHS=200
SAT_STUDIO_SESSION_TTL_SECONDS=2592000
SAT_STUDIO_SESSION_COOKIE_SECURE=true
SAT_STUDIO_SESSION_COOKIE_SAMESITE=Lax
# Future scale-out path. Leave empty until the PostgreSQL adapter and migrations are enabled.
SAT_STUDIO_PUBLIC_DATABASE_URL=
SAT_STUDIO_ENABLE_POSTGRES=false
SAT_PUBLIC_BACKEND_TOKEN=
SAT_PUBLIC_HEALTH_WEBHOOK=
